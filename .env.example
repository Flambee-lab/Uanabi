# Supabase — copiá este archivo a .env.local y completá con tus credenciales
# Vite (recomendado para este proyecto)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key

# Compatibilidad Next.js (opcional)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# En Supabase Dashboard → Authentication → URL Configuration:
# Site URL: http://localhost:5173  (o el puerto que muestre Vite)
# Redirect URLs (agregar TODAS):
#   http://localhost:5173/auth/callback
#   http://localhost:5173/**
#   http://localhost:5173/dashboard?callback=true
#   http://localhost:5173/profile?callback=true
#
# Google OAuth: Authentication → Providers → Google (habilitar + Client ID/Secret de Google Cloud)
# Magic link / confirmación email: Authentication → Email → habilitar "Confirm email" según necesidad
#
# Login 100% local (NO usa Supabase Auth — solo OAuth de redes usa Supabase):
# VITE_USE_LOCAL_AUTH=1
# VITE_DEV_LOGIN_EMAIL=tu@email.com
# VITE_DEV_LOGIN_PASSWORD=tu-password
# VITE_AUTO_SKIP_AUTH=1
#
# Instagram Login (Meta Developers) — en Supabase van en Providers → Facebook (no hay slot Instagram)
# NEXT_PUBLIC_INSTAGRAM_CLIENT_ID=tu-meta-app-id
# NEXT_PUBLIC_INSTAGRAM_CLIENT_SECRET=tu-meta-app-secret
#
# Redes sociales OAuth en Supabase → Providers:
#   Facebook  → credenciales de tu app Meta (para verificar Instagram)
#   Twitter/X → para verificar X

# En SQL Editor, ejecutá supabase/schema.sql
# En Storage, creá el bucket público "evidencias" (o dejá que el schema lo cree)
